# Copy this to .env for local development (never commit .env to Git)
# Set all of these in Netlify UI → Site Settings → Environment Variables

# Firebase
FIREBASE_DATABASE_URL=your_firebase_database_url_here
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"shair-sales",...}

# Meta
META_PIXEL_ID=your_pixel_id_here
META_CAPI_TOKEN=your_capi_access_token_here

# Resend
RESEND_API_KEY=re_your_key_here
